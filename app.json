{
  "expo": {
    "name": "Kenya Baroda Mobi",
    "slug": "barodaapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C8102E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.ke.bankofbaroda.mobi",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to authenticate into your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8102E"
      },
      "package": "co.ke.bankofbaroda.mobi",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "scheme": "barodaapp"
  },
  "main": "index.js"
}
